FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        cmake \
        git \
        lcov \
        libbenchmark-dev \
        liblua5.3-dev \
        libmbedtls-dev \
        ninja-build \
        python3 \
        python3-pip \
        upx-ucl \
        valgrind \
        wget \
    && rm -rf /var/lib/apt/lists/*

COPY docker/requirements.txt /tmp/pikapython-requirements.txt

RUN pip3 install --no-cache-dir -r /tmp/pikapython-requirements.txt \
    && rm /tmp/pikapython-requirements.txt

WORKDIR /workspace
